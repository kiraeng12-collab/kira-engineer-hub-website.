# Kira Engineer Hub backend environment variables
# Add these in Vercel Project Settings > Environment Variables.

# Keep checkout disabled until legal, refund, delivery, and Stripe setup are complete.
CHECKOUT_ENABLED=false

# Form delivery (legacy fallback - used automatically when DATABASE_URL is not set)
FORM_WEBHOOK_URL=
ADMIN_WEBHOOK_URL=

# Database (Vercel Postgres / Neon) - required for form storage, rate limiting,
# and (in later phases) membership/auth/Telegram/Early Bird records.
DATABASE_URL=

# Email (Resend) - confirmation and admin-notification emails for form
# submissions. Forms keep working via FORM_WEBHOOK_URL above if these are unset.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS="Kira Engineer Hub <KE@kiraengineerhub.com>"
ADMIN_NOTIFICATION_EMAIL=

# Authentication (Auth.js / NextAuth v4, credentials-based)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.kiraengineerhub.com

# Stripe checkout
STRIPE_SECRET_KEY=
STRIPE_PRICE_KIRA_VIP_MONTHLY=
STRIPE_PRICE_KIRA_VIP_QUARTERLY=
# Founding Member tier (permanent flat discount for members who joined Kira
# Trading Community 2024-2025: USD 50/month, USD 150/quarter) - separate
# Stripe Prices, used directly instead of a coupon.
STRIPE_PRICE_KIRA_VIP_MONTHLY_FOUNDING=
STRIPE_PRICE_KIRA_VIP_QUARTERLY_FOUNDING=
STRIPE_EARLY_BIRD_COUPON_ID=
STRIPE_SUCCESS_URL=https://www.kiraengineerhub.com/checkout/success
STRIPE_CANCEL_URL=https://www.kiraengineerhub.com/checkout/cancelled

# Stripe webhook - configure this endpoint in the Stripe Dashboard:
# https://www.kiraengineerhub.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Telegram membership onboarding (see docs/backend-phase-7.md for setup).
# Bot token and username from @BotFather; group chat ID from the private
# VIP group the bot has been added to as an admin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_GROUP_CHAT_ID=

# Telegram webhook - register with setWebhook using this URL and secret_token:
# https://www.kiraengineerhub.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
